{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OCI Vue",
  "version": "0.1.0",
  "identifier": "com.astro24002.oci-vue",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OCI Vue",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"]
  }
}
